{
  "name": "cag-trading-app",
  "version": "1.0.35",
  "description": "C.A.G. Trading — Flight PDF to Excel converter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always",
    "release:patch": "npm version patch -m \"v%s\" && npm run publish && git push --follow-tags",
    "release:minor": "npm version minor -m \"v%s\" && npm run publish && git push --follow-tags"
  },
  "author": "C.A.G. Trading",
  "license": "UNLICENSED",
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cagtrading.flightconverter",
    "productName": "C.A.G. Trading",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "C.A.G. Trading"
    },
    "publish": {
      "provider": "github",
      "owner": "deniznizzzzz-hash",
      "repo": "CAGTRADINGAPP",
      "releaseType": "release"
    }
  }
}
